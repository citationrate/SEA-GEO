# ================================================
# AI Visibility Index (AVI) — Environment Variables
# 1. Copia questo file: cp .env.example .env.local
# 2. Riempi i valori
# 3. Su Vercel: aggiungi le stesse variabili in
#    Project Settings → Environment Variables
# ================================================

# --- Supabase (dalla tua dashboard Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- LLM Providers (aggiungi solo quelle che hai) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...
GROK_API_KEY=xai-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- CitationRate Backend (consent/privacy endpoints) ---
NEXT_PUBLIC_CR_BACKEND_URL=http://localhost:8000

# --- Email (Resend) — usato da /api/support e /api/consultation ---
# Senza RESEND_API_KEY l'invio dal form Supporto fallisce.
RESEND_API_KEY=re_...
# Mittente: deve essere un dominio verificato su Resend (es. noreply@aicitationrate.com)
RESEND_FROM_EMAIL=noreply@aicitationrate.com
# Destinatario interno per i ticket di supporto / richieste consulenza
CONSULTATION_EMAIL=info@citationrate.com
